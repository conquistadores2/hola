# Copia este archivo como ".env" para probar en tu PC.
# En Railway, esta variable se configura en el dashboard (Variables), NO en este archivo.

DISCORD_TOKEN=pega_aqui_el_token_de_tu_bot

# Opcional: carpeta donde se guardan los JSON de configuración por servidor.
# En Railway, apunta esto a la carpeta donde montes un Volume (ver README).
DATA_DIR=data

# Opcional: prefijo para los comandos de texto (ej: "!whitelist list").
# Los comandos también funcionan siempre como slash ("/whitelist list")
# sin importar este valor. Por defecto "!".
COMMAND_PREFIX=!
